# Neon PostgreSQL 資料庫連線
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname

# Auth.js v5 金鑰 (產生方式: openssl rand -hex 32)
AUTH_SECRET=your-secret-key

# GitHub OAuth 配置
# 申請: https://github.com/settings/developers -> New OAuth App
# Homepage URL: http://localhost:3000 (開發) / 部署 URL (生產)
# Callback URL: http://localhost:3000/api/auth/callback/github (開發)
#               https://<your-domain>/api/auth/callback/github (生產)
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# 開發環境需要設定，生產環境 (Vercel) 會自動從 request header 取得
NEXTAUTH_URL=http://localhost:3000
